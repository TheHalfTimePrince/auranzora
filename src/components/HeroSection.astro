---
import LogoIcon from './LogoIcon.astro';
import LogoText from './LogoText.astro';
---

<section class="pt-28 md:pt-40 pb-16 md:pb-24 px-6 md:px-10 relative overflow-hidden">
  <div class="absolute top-20 right-0 w-[40vw] h-[40vw] bg-ochre/10 -translate-y-1/4 translate-x-1/4 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[25vw] h-[25vw] bg-terracotta/8 pointer-events-none"></div>

  <div class="container mx-auto max-w-7xl relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-center gap-12 lg:gap-16">

      <div class="lg:w-1/2 flex flex-col gap-8">
        <div class="flex items-center gap-2">
          <LogoIcon class="h-10 w-10 md:h-12 md:w-12" />
          <LogoText class="h-8 md:h-10" />
        </div>

        <h1
          class="text-4xl md:text-5xl font-bold leading-[1.1] tracking-[-0.02em] text-charcoal"
          style="font-family: var(--font-heading)"
        >
          Digital agency for the modern web
        </h1>

        <p class="text-base md:text-lg leading-relaxed text-charcoal/60">
          We build search-optimized websites and brand identities that drive measurable growth.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-2">
          <a
            href="#contact"
            class="btn-bauhaus px-8 py-4 bg-terracotta text-sand font-semibold text-sm uppercase tracking-[0.1em] text-center"
          >
            Get Started
          </a>
          <a
            href="#work"
            class="px-8 py-4 border border-charcoal text-charcoal font-semibold text-sm uppercase tracking-[0.1em] text-center hover:bg-charcoal hover:text-sand"
            style="transition: none"
          >
            View Our Work
          </a>
        </div>
      </div>

      <div class="lg:w-1/2 relative">
        <div
          class="relative w-full aspect-4/3 overflow-hidden bg-charcoal"
          style="clip-path: polygon(0 0, 100% 0, 100% calc(100% - 24px), calc(100% - 24px) 100%, 0 100%)"
        >
          <video
            autoplay
            muted
            loop
            playsinline
            class="w-full h-full object-cover"
            poster="/bento/vitaly-gariev-JOBvWZIaWNo-unsplash.jpg"
          >
            <source src="/hero-video.mp4" type="video/mp4" />
          </video>
          <div class="absolute inset-0 bg-charcoal/20 mix-blend-multiply pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>
