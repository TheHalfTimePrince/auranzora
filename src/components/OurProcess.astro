---
interface ProcessStep {
  number: string;
  title: string;
  description: string;
}

const processSteps: ProcessStep[] = [
  {
    number: "01",
    title: "Discovery",
    description: "We dive deep into understanding your business, goals, audience, and competition. This foundation ensures every decision is strategically aligned.",
  },
  {
    number: "02",
    title: "Strategy",
    description: "We craft a comprehensive roadmap that outlines the approach, timeline, and deliverables. Every element is designed to maximize your ROI.",
  },
  {
    number: "03",
    title: "Design",
    description: "Our designers create stunning visuals that capture your brand essence. Every pixel is purposeful, every interaction is meaningful.",
  },
  {
    number: "04",
    title: "Development",
    description: "We build with modern technologies and best practices. Clean code, fast performance, and search optimization are non-negotiable standards.",
  },
  {
    number: "05",
    title: "Launch & Optimize",
    description: "We ensure a smooth launch and continue to monitor, test, and optimize. Your success is an ongoing commitment, not a one-time delivery.",
  },
];
---

<section id="process" class="py-20 md:py-28 px-6 md:px-10 border-t border-charcoal/10">
  <div class="container mx-auto max-w-5xl">
    <div class="mb-14 md:mb-20 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="text-xs uppercase tracking-[0.2em] text-ochre font-medium block mb-3">
          How We Work
        </span>
        <h2
          class="text-4xl md:text-5xl font-bold text-charcoal leading-tight tracking-[-0.02em]"
          style="font-family: var(--font-heading)"
        >
          Our Process
        </h2>
      </div>
      <p class="text-charcoal/50 text-sm md:text-base max-w-sm">
        A proven approach that delivers results. Every project follows our battle-tested methodology.
      </p>
    </div>

    <div id="process-steps">
      {processSteps.map((step) => (
        <div class="process-step border-t border-charcoal/10 last:border-b opacity-0 translate-y-[30px]">
          <div
            class="grid grid-cols-12 gap-4 md:gap-8 py-8 md:py-12 group hover:bg-parchment items-start px-2 md:px-4"
            style="transition: background-color 0.1s"
          >
            <div class="col-span-2 md:col-span-1">
              <span
                class="text-3xl md:text-4xl font-bold text-terracotta/40 group-hover:text-terracotta"
                style="font-family: var(--font-heading); transition: color 0.1s"
              >
                {step.number}
              </span>
            </div>

            <div class="col-span-10 md:col-span-3">
              <h3
                class="text-xl md:text-2xl font-bold text-charcoal"
                style="font-family: var(--font-heading)"
              >
                {step.title}
              </h3>
            </div>

            <div class="col-span-12 md:col-span-8 md:col-start-5">
              <p class="text-charcoal/60 leading-relaxed text-sm md:text-base">
                {step.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.process-step').forEach((step) => {
    gsap.to(step, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: step,
        start: 'top 85%',
        once: true,
      },
    });
  });
</script>
