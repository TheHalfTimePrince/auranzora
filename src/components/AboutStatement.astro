---
import LogoIcon from './LogoIcon.astro';
import LogoText from './LogoText.astro';
---

<section class="py-16 md:py-24 px-6 md:px-10 border-t border-charcoal/10">
  <div class="container mx-auto max-w-4xl">
    <p
      class="text-lg md:text-2xl lg:text-[1.7rem] leading-relaxed tracking-[-0.01em] text-charcoal/80"
      style="font-family: var(--font-heading)"
    >
      <span class="inline-flex items-center gap-1 md:gap-2 align-middle overflow-visible -mt-1 md:-mt-2">
        <LogoIcon class="h-4 w-4 md:h-5 md:w-5" />
        <LogoText class="h-3 md:h-5" />
      </span>
      <span class="text-sm md:text-base text-charcoal/50"> is a </span>
      <span>digital agency building </span>
      <span class="text-terracotta font-semibold">search-optimized websites</span>
      <span class="text-sm md:text-base text-charcoal/50"> and </span>
      <span class="text-sage font-semibold">brand identities</span>
      <span class="text-sm md:text-base text-charcoal/50"> for </span>
      <span class="font-bold text-ochre">modern</span>
      <span> businesses. From technical web development to complete visual systems, if you need a functional online presence built for </span>
      <span class="text-terracotta font-semibold">search visibility</span>
      <span> and professional recognition in 2026, we can design it.</span>
    </p>
  </div>
</section>
