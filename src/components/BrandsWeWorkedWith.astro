---
const brands = [
  "TechCorp", "InnovateLabs", "FutureScale", "GrowthWorks",
  "DigitalFirst", "CloudVenture", "NextGen", "Momentum",
  "Velocity", "Catalyst", "Paradigm", "Synergy",
];

const duplicated = [...brands, ...brands];
---

<section id="brands" class="py-16 md:py-24 border-t border-charcoal/10 overflow-hidden">
  <div class="container mx-auto max-w-7xl px-6 md:px-10 mb-10">
    <span class="text-xs uppercase tracking-[0.2em] text-terracotta font-medium block mb-3">
      Trusted By
    </span>
    <h2
      class="text-3xl md:text-4xl font-bold tracking-[-0.02em] text-charcoal"
      style="font-family: var(--font-heading)"
    >
      Brands We've Worked With
    </h2>
  </div>

  <div class="relative w-full overflow-hidden border-y border-charcoal/10 py-8">
    <div class="marquee-track flex items-center gap-16 w-max">
      {duplicated.map((brand, i) => (
        <span
          class="text-2xl md:text-4xl font-bold tracking-[-0.02em] text-charcoal/15 hover:text-terracotta whitespace-nowrap cursor-default select-none"
          style="font-family: var(--font-heading); transition: color 0.1s"
        >
          {brand}
        </span>
      ))}
    </div>
  </div>

  <div class="relative w-full overflow-hidden border-b border-charcoal/10 py-8">
    <div class="marquee-track flex items-center gap-16 w-max" style="animation-direction: reverse; animation-duration: 40s">
      {duplicated.map((brand, i) => (
        <span
          class="text-2xl md:text-4xl font-bold tracking-[-0.02em] text-charcoal/15 hover:text-sage whitespace-nowrap cursor-default select-none"
          style="font-family: var(--font-heading); transition: color 0.1s"
        >
          {brand}
        </span>
      ))}
    </div>
  </div>
</section>
