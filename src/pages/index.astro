---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutStatement from '../components/AboutStatement.astro';
import WorkShowcase from '../components/WorkShowcase.astro';
import BrandsWeWorkedWith from '../components/BrandsWeWorkedWith.astro';
import Reviews from '../components/Reviews.astro';
import OurProcess from '../components/OurProcess.astro';
---

<Base>
  <main class="relative z-10 min-h-screen">
    <HeroSection />
    <AboutStatement />
    <WorkShowcase />
    <BrandsWeWorkedWith />
    <Reviews />
    <OurProcess />

    <section id="contact" class="bg-terracotta text-sand">
      <div class="container mx-auto max-w-5xl px-6 md:px-10 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
          <div>
            <span class="text-xs uppercase tracking-[0.2em] text-sand/60 font-medium block mb-3">
              Let's Talk
            </span>
            <h2
              class="text-4xl md:text-6xl font-bold leading-tight tracking-[-0.02em]"
              style="font-family: var(--font-heading)"
            >
              Ready to Start?
            </h2>
            <p class="text-lg text-sand/70 mt-4 max-w-lg">
              Let's discuss how we can help transform your digital presence. Get in touch for a free consultation.
            </p>
          </div>
          <a
            href="mailto:hello@subliminal.studio"
            class="btn-bauhaus inline-block px-10 py-5 bg-charcoal text-sand font-semibold text-sm uppercase tracking-[0.1em] text-center shrink-0"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
